{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "rpc/rbe-pickleball",
  "description": "Rosales Pickleball Club — Vercel deployment root",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "vercel": [
      "composer install --working-dir=backend --no-dev --optimize-autoloader --no-interaction --no-scripts"
    ]
  }
}
