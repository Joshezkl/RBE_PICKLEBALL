{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "frontend/lib/main.dart",
      "cwd": "frontend",
      "args": [
        "-d",
        "chrome",
        "--dart-define=API_BASE_URL=http://localhost:8000/api"
      ]
    }
  ]
}
