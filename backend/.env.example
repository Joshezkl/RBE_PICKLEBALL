APP_NAME="Rosales Pickleball Club"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production: set to your public API URL (HTTPS).
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rpc_queue
DB_USERNAME=root
DB_PASSWORD=

# SQLite fallback for local testing without MySQL:
# DB_CONNECTION=sqlite

# PERFORMANCE: reuse the DB connection across requests instead of opening a new
# TLS connection (~300-500ms) every time. Big win on a remote DB (TiDB Cloud)
# and on warm serverless instances / always-on hosts. Safe to enable in prod.
# DB_PERSISTENT=true

# Co-locate the database in the SAME region as the app (Vercel function region
# or your VPS). Cross-region DB round trips are the dominant source of the
# ~500ms-per-request latency seen in deployment.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

ADMIN_PIN=1234

# Vercel production — set in Project → Environment Variables:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.vercel.app
# APP_KEY=base64:...   (run: php artisan key:generate --show)
# LOG_CHANNEL=stderr
# ADMIN_PIN=your-strong-pin
# DB_CONNECTION=mysql
# DB_HOST=...
# DB_DATABASE=rpc_queue
# DB_USERNAME=...
# DB_PASSWORD=...

# TiDB Cloud requires TLS. The app bundles ISRG Root X1 at storage/certs/isrgrootx1.pem.
# Optional override:
# MYSQL_ATTR_SSL_CA=/custom/path/to/ca.pem
# MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false
#
# Leave API_BASE_URL unset — the build auto-uses https://<vercel-domain>/api
# Do NOT point API_BASE_URL at Railway or other external API hosts.

# Laravel Reverb (optional — enable for live websocket updates)
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=rpc-app
# REVERB_APP_KEY=rpc-key
# REVERB_APP_SECRET=rpc-secret
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
# Production Reverb example:
# REVERB_HOST=api.yourdomain.com
# REVERB_PORT=443
# REVERB_SCHEME=https
# REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# PERFORMANCE: the high-traffic read endpoints (/sessions/{id}/live, /state,
# /sessions/active, leaderboards) are micro-cached and invalidated on every
# write, so many concurrent pollers collapse into a single DB build per window.
# For the biggest win on serverless/remote-DB setups, point the cache at Redis
# (e.g. Upstash) so cached reads never open a database connection at all:
# CACHE_STORE=redis
# REDIS_HOST=...
# REDIS_PORT=6379
# REDIS_PASSWORD=...
#
# Cache TTLs in seconds (set to 0 to disable a given cache):
# RPC_LIVE_CACHE_TTL=3
# RPC_STATE_CACHE_TTL=5
# RPC_LEADERBOARD_CACHE_TTL=60

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
