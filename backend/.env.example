APP_NAME="Rosales Pickleball Club"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production: set to your public API URL (HTTPS).
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rpc_queue
DB_USERNAME=root
DB_PASSWORD=

# SQLite fallback for local testing without MySQL:
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

ADMIN_PIN=1234

# Vercel production — set in Project → Environment Variables:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.vercel.app
# APP_KEY=base64:...   (run: php artisan key:generate --show)
# LOG_CHANNEL=stderr
# ADMIN_PIN=your-strong-pin
# DB_CONNECTION=mysql
# DB_HOST=...
# DB_DATABASE=rpc_queue
# DB_USERNAME=...
# DB_PASSWORD=...

# TiDB Cloud (and other hosted MySQL) require TLS. Download the CA cert from
# TiDB Connect dialog, save as backend/storage/certs/tidb-ca.pem, then set:
# MYSQL_ATTR_SSL_CA=/var/task/backend/storage/certs/tidb-ca.pem
# MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false
#
# Leave API_BASE_URL unset — the build auto-uses https://<vercel-domain>/api
# Do NOT point API_BASE_URL at Railway or other external API hosts.

# Laravel Reverb (optional — enable for live websocket updates)
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=rpc-app
# REVERB_APP_KEY=rpc-key
# REVERB_APP_SECRET=rpc-secret
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
# Production Reverb example:
# REVERB_HOST=api.yourdomain.com
# REVERB_PORT=443
# REVERB_SCHEME=https
# REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
